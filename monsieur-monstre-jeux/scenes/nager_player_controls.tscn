[sub_resource type="GDScript" id="GDScript_dj4g1"]
script/source = "extends Node2D

@export var player_index = 0;
var input_velocity = Vector2.ZERO;
var speed = 700;
var legs_cooldown = 0.5;

func _ready():
	pass

func _physics_process(delta: float) -> void:
	input_velocity = Vector2.ZERO
	
	if Input.is_joy_button_pressed(player_index, JOY_BUTTON_A):
		input_velocity += Vector2.UP * speed;
	
	input_velocity+=Vector2.DOWN*delta*$RigidBody2D.gravity_scale*1000
	
	position+=input_velocity*delta
"

