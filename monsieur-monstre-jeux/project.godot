config_version=5

[application]

config/name="Monsieur Monstre Jeux"
run/main_scene="uid://bfbny43birx8b"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://sprites/icon.svg"

[autoload]

PlayerData="res://scripts/core/player_data.gd"

[display]

window/size/viewport_width=1024
window/size/viewport_height=768
window/stretch/mode="2d"
window/stretch/aspect="keep"
window/size/window_width_override=1024
window/size/window_height_override=768

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_mcp/plugin.cfg")

